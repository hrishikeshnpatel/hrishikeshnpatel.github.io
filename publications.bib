@misc{tenkila_ab_2022,
	title = {Ab initio in-medium similarity renormalization group for open-shell atomic systems},
	url = {http://arxiv.org/abs/2212.08188},
	doi = {10.48550/arXiv.2212.08188},
	abstract = {Precise theoretical calculations of open-shell atomic systems are critical for extracting fundamental physics parameters from precision experiments. Here we present proof-of-principle calculations illustrating the effectiveness of the valence-space formulation of the ab initio in-medium similarity renormalization group, widely used in nuclear theory, as a new ab initio method for atomic systems. We adapt this approach to study properties of closed- and open-shell many-electron systems from helium to calcium. Ground-state energies, excitation spectra, and ionization energies are obtained for selected atoms, and reasonable agreement is found with benchmark coupled-cluster and many-body perturbation theory calculations, where available.},
	urldate = {2024-06-03},
	publisher = {arXiv},
	author = {Tenkila, G. and Chand, V. and Miyagi, T. and Patel, H. and Stroberg, S. R. and Ruiz, R. F. Garcia and Holt, J. D.},
	month = dec,
	year = {2022},
	note = {arXiv:2212.08188 [nucl-ex, physics:nucl-th, physics:physics]},
	keywords = {Nuclear Experiment, Nuclear Theory, Physics - Atomic Physics},
	file = {arXiv Fulltext PDF:/Users/hrishikesh/Zotero/storage/6PZBAJNF/Tenkila et al. - 2022 - Ab initio in-medium similarity renormalization gro.pdf:application/pdf;arXiv.org Snapshot:/Users/hrishikesh/Zotero/storage/YELGXEHP/2212.html:text/html},
}

@article{wani_compactification_2021,
	title = {Compactification, {T}-duality and quantum erasers},
	volume = {36},
	issn = {0217-751X},
	url = {https://www.worldscientific.com/doi/abs/10.1142/S0217751X21501025},
	doi = {10.1142/S0217751X21501025},
	abstract = {Using T-duality, we will argue that a zero point length exists in the low-energy effective field theory of string theory on compactified extra dimensions. Furthermore, if we neglect all the oscillator modes, this zero point length would modify low quantum mechanical systems. As this zero length is fixed geometrically, it is important to analyze how it modifies purely quantum mechanical effects. Thus, we will analyze its effects on quantum erasers, because they are based on quantum effects like entanglement. It will be observed that the behavior of these quantum erasers gets modified by this zero point length. As the zero point length is fixed by the radius of compactification, we argue that these results demonstrate a deeper connection between geometry and quantum effects.},
	number = {18},
	urldate = {2024-06-03},
	journal = {International Journal of Modern Physics A},
	author = {Wani, Salman Sajad and Sutherland, Dylan and Pourhassan, Behnam and Faizal, Mir and Patel, Hrishikesh},
	month = jun,
	year = {2021},
	note = {Publisher: World Scientific Publishing Co.},
	keywords = {entanglement, Zero point length},
	pages = {2150102},
	file = {Submitted Version:/Users/hrishikesh/Zotero/storage/XKL4TDNG/Wani et al. - 2021 - Compactification, T-duality and quantum erasers.pdf:application/pdf},
}
